---
const companies = [
  { name: "San Cristóbal Seguros", logo: "/logos/san-cristobal.png" },
  { name: "Federación Patronal Seguros", logo: "/logos/federacion-patronal.png" },
  { name: "Mercantil Andina", logo: "/logos/mercantil-andina.png" },
  { name: "La Segunda Seguros", logo: "/logos/la-segunda.png" },
  { name: "Provincia Seguros", logo: "/logos/provincia-seguros.webp" },
  { name: "Nación Seguros", logo: "/logos/nacion-seguros.png" },
];
---

<section
  id="inicio"
  class="relative flex min-h-screen items-center overflow-hidden bg-gradient-to-br from-primary-dark via-primary to-primary-light"
>
  <!-- Animated background shapes -->
  <div class="absolute inset-0 overflow-hidden">
    <div
      class="hero-shape absolute -top-1/4 -right-1/4 h-[600px] w-[600px] rounded-full bg-accent/10 blur-3xl"
    >
    </div>
    <div
      class="hero-shape absolute -bottom-1/4 -left-1/4 h-[500px] w-[500px] rounded-full bg-primary-light/20 blur-3xl"
    >
    </div>
    <div
      class="hero-shape absolute top-1/2 left-1/2 h-[400px] w-[400px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent/5 blur-2xl"
    >
    </div>
  </div>

  <!-- Grid pattern overlay -->
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 pt-32 pb-32">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left column: Text -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div
          class="hero-badge mb-8 inline-flex flex-col items-center gap-1 rounded-2xl border border-white/20 bg-white/10 px-5 py-3 backdrop-blur-sm"
        style="opacity: 0; transform: translateY(20px)"
        >
          <span class="flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-accent animate-pulse"></span>
            <span class="text-sm font-medium text-white/90">Productor Asesor de Seguros</span>
          </span>
          <span class="text-xs font-medium text-white/60">Mat. 101.762</span>
        </div>

        <!-- Headline -->
        <h1 class="hero-title mb-6 text-4xl leading-tight font-extrabold tracking-tight text-white md:text-7xl md:leading-tight" style="opacity: 0; transform: translateY(20px)">
          Protegemos lo que
          <span class="text-accent">más valorás</span>
          con profesionalismo y calidad
        </h1>

        <!-- Subtitle -->
        <p
          class="hero-subtitle mb-10 max-w-xl mx-auto lg:mx-0 text-lg leading-relaxed text-white/80 md:text-xl"
        style="opacity: 0; transform: translateY(20px)"
        >
          Asesoramiento integral y rápido para encontrar la cobertura perfecta
          para tu auto, hogar o empresa. Tu tranquilidad es nuestra prioridad.
        </p>

        <!-- CTAs -->
        <div class="hero-ctas flex flex-col items-center gap-4 sm:flex-row lg:items-start" style="opacity: 0; transform: translateY(20px)">
          <a
            href="#contacto"
            class="group inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-full bg-accent px-8 py-4 text-lg font-bold text-dark transition-all hover:scale-105 hover:bg-accent-dark hover:shadow-xl hover:shadow-accent/25"
          >
            Cotizá tu Seguro
            <svg
              class="h-5 w-5 transition-transform group-hover:translate-x-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
            >
          </a>
          <a
            href="#companias"
            class="inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-full border-2 border-white/30 px-8 py-4 text-lg font-semibold text-white transition-all hover:border-white/60 hover:bg-white/10"
          >
            Compañías de Seguros
          </a>
        </div>
      </div>

      <!-- Right column: Logo grid -->
      <div class="hero-logos hidden lg:block">
        <div class="grid grid-cols-2 gap-5">
          {
            companies.map((company) => (
              <div class="hero-logo-card flex items-center justify-center rounded-2xl border border-muted-light/10 bg-white p-10 shadow-lg transition-all duration-300 hover:shadow-xl" style="opacity: 0; transform: translateY(20px)">
                <img
                  src={company.logo}
                  alt={company.name}
                  class="h-20 w-auto max-w-[260px] object-contain"
                  loading="eager"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="hero-scroll absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce"
  >
    <svg class="h-6 w-6 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>
