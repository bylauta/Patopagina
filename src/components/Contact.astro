---

---

<section id="contacto" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-12 lg:grid-cols-2">
      <!-- Info side -->
      <div>
        <span
          class="mb-4 inline-block rounded-full bg-accent/10 px-4 py-1.5 text-sm font-semibold text-accent-dark"
        >
          Contacto
        </span>
        <h2
          class="section-title mb-6 text-4xl font-extrabold tracking-tight text-dark"
        >
          Cotizá tu seguro gratis
        </h2>
        <p class="section-description mb-10 text-lg leading-relaxed text-muted">
          Recibí asesoramiento personalizado y sin costo. Cotizamos tu seguro de auto, hogar, moto o comercio con las mejores compañías de Argentina.
        </p>

        <div class="space-y-6">
          <!-- Email -->
          <a
            href="mailto:pwardpas@gmail.com"
            class="flex items-center gap-4 text-muted transition-colors hover:text-primary"
          >
            <div
              class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary"
            >
              <svg
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-dark">Email</div>
              <div>pwardpas@gmail.com</div>
            </div>
          </a>

          <!-- Phone -->
          <a
            href="tel:+5491157054479"
            class="flex items-center gap-4 text-muted transition-colors hover:text-primary"
          >
            <div
              class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary"
            >
              <svg
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-dark">Teléfono</div>
              <div>11 5705-4479</div>
            </div>
          </a>

          <!-- WhatsApp -->
          <a
            href="https://wa.me/5491157054479"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 text-muted transition-colors hover:text-green-600"
          >
            <div
              class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-green-500/10 text-green-600"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
                ></path>
                <path
                  d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.75.75 0 00.913.913l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.319 0-4.46-.778-6.171-2.088l-.43-.34-2.634.883.883-2.634-.34-.43A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"
                ></path>
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-dark">WhatsApp</div>
              <div>Chateá con nosotros</div>
            </div>
          </a>
        </div>
      </div>

      <!-- Form side -->
      <div class="rounded-3xl border border-muted-light/20 bg-background p-8 shadow-sm lg:p-10">
        <form
          action="https://formspree.io/f/placeholder"
          method="POST"
          class="space-y-5"
        >
          <div>
            <label for="name" class="mb-2 block text-sm font-medium text-dark"
              >Nombre y Apellido</label
            >
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full rounded-xl border border-muted-light/30 bg-white px-4 py-3 text-dark outline-none transition-all focus:border-primary focus:ring-2 focus:ring-primary/20"
              placeholder="Tu nombre completo"
            />
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label
                for="email"
                class="mb-2 block text-sm font-medium text-dark">Email</label
              >
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-xl border border-muted-light/30 bg-white px-4 py-3 text-dark outline-none transition-all focus:border-primary focus:ring-2 focus:ring-primary/20"
                placeholder="tu@email.com"
              />
            </div>
            <div>
              <label
                for="phone"
                class="mb-2 block text-sm font-medium text-dark">Teléfono</label
              >
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full rounded-xl border border-muted-light/30 bg-white px-4 py-3 text-dark outline-none transition-all focus:border-primary focus:ring-2 focus:ring-primary/20"
                placeholder="11 1234-5678"
              />
            </div>
          </div>

          <div>
            <label
              for="insurance-type"
              class="mb-2 block text-sm font-medium text-dark"
              >¿Qué querés asegurar?</label
            >
            <select
              id="insurance-type"
              name="insurance_type"
              class="w-full rounded-xl border border-muted-light/30 bg-white px-4 py-3 text-dark outline-none transition-all focus:border-primary focus:ring-2 focus:ring-primary/20"
            >
              <option value="">Seleccioná una opción</option>
              <option value="auto">Auto</option>
              <option value="moto">Moto</option>
              <option value="hogar">Hogar</option>
              <option value="comercio">Comercio</option>
              <option value="art">ART</option>
              <option value="electronicos">Equipos Electrónicos</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div>
            <label
              for="message"
              class="mb-2 block text-sm font-medium text-dark"
              >Contanos brevemente</label
            >
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full resize-none rounded-xl border border-muted-light/30 bg-white px-4 py-3 text-dark outline-none transition-all focus:border-primary focus:ring-2 focus:ring-primary/20"
              placeholder="Detalles adicionales sobre lo que necesitás..."></textarea>
          </div>

          <button
            type="submit"
            class="w-full rounded-xl bg-primary px-6 py-4 text-lg font-bold text-white transition-all hover:bg-primary-dark hover:shadow-lg hover:shadow-primary/25"
          >
            Enviar Consulta
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
