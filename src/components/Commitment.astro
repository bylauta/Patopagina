---

---

<section class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="commitment-container grid items-center gap-12 md:grid-cols-2">
      <!-- Image side -->
      <div class="relative">
        <div
          class="aspect-square overflow-hidden rounded-3xl bg-gradient-to-br from-primary-dark to-primary"
        >
          <div class="flex h-full items-center justify-center p-8">
            <img
              src="/logo.png"
              alt="Pato Ward Asesor de Seguros"
              class="w-[90%] brightness-0 invert"
            />
          </div>
        </div>
        <!-- Decorative elements -->
        <div
          class="absolute -right-4 -bottom-4 -z-10 h-full w-full rounded-3xl bg-accent/20"
        >
        </div>
      </div>

      <!-- Text side -->
      <div>
        <span
          class="mb-4 inline-block rounded-full bg-accent/10 px-4 py-1.5 text-sm font-semibold text-accent-dark"
        >
          Nuestro Compromiso
        </span>
        <h2
          class="section-title mb-6 text-4xl font-extrabold tracking-tight text-dark"
        >
          Nuestro compromiso es con tu tranquilidad
        </h2>
        <p class="mb-6 text-lg leading-relaxed text-muted">
          Nuestra dedicación se refleja en cada detalle. Brindamos un servicio
          profesional diseñado para proteger lo que más importa, con la agilidad
          y confianza que tu patrimonio, empresa y familia merecen.
        </p>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg
              class="mt-0.5 h-6 w-6 flex-shrink-0 text-accent"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-muted"
              >Asesoramiento claro y sin vueltas para cada una de tus
              necesidades</span
            >
          </li>
          <li class="flex items-start gap-3">
            <svg
              class="mt-0.5 h-6 w-6 flex-shrink-0 text-accent"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-muted"
              >Eficacia y rapidez en la resolución de siniestros</span
            >
          </li>
          <li class="flex items-start gap-3">
            <svg
              class="mt-0.5 h-6 w-6 flex-shrink-0 text-accent"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-muted"
              >Respaldo de las mejores compañías del mercado argentino</span
            >
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
