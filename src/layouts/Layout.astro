---
interface Props {
  title?: string;
  description?: string;
}

const SITE_URL = "https://www.patowardseguros.com";
const SITE_NAME = "Pato Ward Asesor de Seguros";

const {
  title = "Pato Ward | Asesor de Seguros en Argentina — Cotizá Online",
  description = "Cotizá seguros de auto, moto, hogar, comercio y ART. Asesoramiento gratuito con San Cristóbal, La Segunda, Federación Patronal y más. Mat. SSN 101.762.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE_URL);

const insuranceAgencySchema = {
  "@context": "https://schema.org",
  "@type": "InsuranceAgency",
  "@id": `${SITE_URL}/#organization`,
  name: SITE_NAME,
  alternateName: "Pato Ward PAS",
  description: "Productor Asesor de Seguros matriculado. Asesoramiento integral en seguros de auto, moto, hogar, comercio, ART y equipos electrónicos en Argentina.",
  url: SITE_URL,
  email: "pwardpas@gmail.com",
  telephone: "+54 9 11 5705-4479",
  priceRange: "$$",
  currenciesAccepted: "ARS",
  paymentAccepted: "Transferencia bancaria, Tarjeta de crédito, Tarjeta de débito, CBU",
  areaServed: {
    "@type": "Country",
    name: "Argentina",
    sameAs: "https://es.wikipedia.org/wiki/Argentina",
  },
  serviceArea: {
    "@type": "GeoCircle",
    geoMidpoint: {
      "@type": "GeoCoordinates",
      latitude: -34.6037,
      longitude: -58.3816,
    },
    geoRadius: "1000000",
  },
  knowsLanguage: "es",
  slogan: "Protegemos lo que más valorás",
  foundingDate: "2014",
  hasCredential: {
    "@type": "EducationalOccupationalCredential",
    credentialCategory: "Matrícula SSN",
    recognizedBy: {
      "@type": "GovernmentOrganization",
      name: "Superintendencia de Seguros de la Nación",
      url: "https://www.argentina.gob.ar/ssn",
    },
    identifier: "101.762",
  },
  makesOffer: [
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Seguro de Auto",
        description: "Seguros de automóvil con cobertura total, terceros completo y responsabilidad civil. Cotización online inmediata.",
        serviceType: "Seguro automotor",
      },
    },
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Seguro de Moto",
        description: "Seguros para motos con cobertura integral. Protección para todo tipo de motovehículos.",
        serviceType: "Seguro de motovehículo",
      },
    },
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Seguro de Hogar",
        description: "Seguros para el hogar con cobertura contra robo, incendio, daños por agua y responsabilidad civil.",
        serviceType: "Seguro de hogar",
      },
    },
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Seguro de Comercio",
        description: "Seguros integrales para comercios y empresas. Protección patrimonial y de responsabilidad civil.",
        serviceType: "Seguro comercial",
      },
    },
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "ART - Aseguradora de Riesgos del Trabajo",
        description: "Seguros de riesgo de trabajo para proteger a empleados y cumplir con la normativa vigente.",
        serviceType: "Seguro de riesgos del trabajo",
      },
    },
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Seguro de Equipos Electrónicos",
        description: "Cobertura para notebooks, celulares y equipos electrónicos contra robo, daño accidental y más.",
        serviceType: "Seguro de equipos electrónicos",
      },
    },
  ],
  brand: [
    { "@type": "Brand", name: "San Cristóbal Seguros" },
    { "@type": "Brand", name: "La Segunda Seguros" },
    { "@type": "Brand", name: "Federación Patronal Seguros" },
    { "@type": "Brand", name: "Mercantil Andina" },
    { "@type": "Brand", name: "Nación Seguros" },
    { "@type": "Brand", name: "Provincia Seguros" },
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.9",
    reviewCount: "500",
    bestRating: "5",
  },
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE_URL}/#website`,
  url: SITE_URL,
  name: SITE_NAME,
  description,
  publisher: { "@id": `${SITE_URL}/#organization` },
  inLanguage: "es-AR",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Qué tipos de seguro ofrecen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ofrecemos seguros para auto, moto, hogar, comercio, ART y equipos electrónicos. Trabajamos con las principales compañías del mercado argentino: San Cristóbal, La Segunda, Federación Patronal, Mercantil Andina, Nación Seguros y Provincia Seguros.",
      },
    },
    {
      "@type": "Question",
      name: "¿Cuánto tarda en activarse mi póliza?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Una vez que elegís tu cobertura y completás la documentación, la póliza se activa de forma inmediata. Nuestro proceso es ágil y sin burocracia innecesaria.",
      },
    },
    {
      "@type": "Question",
      name: "¿Cómo hago un reclamo por siniestro?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Contactanos por WhatsApp o email y nos encargamos de gestionar todo el proceso. Te acompañamos en cada paso hasta la resolución del siniestro con eficacia y rapidez.",
      },
    },
    {
      "@type": "Question",
      name: "¿Puedo comparar precios entre compañías de seguros?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, trabajamos con 6 compañías líderes del mercado argentino. Te presentamos cotizaciones comparativas para que elijas la mejor opción en precio y cobertura.",
      },
    },
    {
      "@type": "Question",
      name: "¿El asesoramiento en seguros tiene costo?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No, nuestro asesoramiento es completamente gratuito. Nuestro trabajo es ayudarte a encontrar la cobertura ideal sin ningún costo adicional.",
      },
    },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: SITE_URL,
    },
  ],
};
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Pato Ward" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Keywords (secondary signal) -->
    <meta name="keywords" content="seguros argentina, cotizar seguro auto, seguro de auto online, seguro hogar, seguro moto, seguro comercio, ART, asesor de seguros, productor de seguros, San Cristóbal seguros, La Segunda seguros, Federación Patronal, Mercantil Andina, Nación Seguros, Provincia Seguros, cotización seguro online, seguro barato argentina" />

    <!-- Geo Tags (SEO Local) -->
    <meta name="geo.region" content="AR" />
    <meta name="geo.placename" content="Buenos Aires, Argentina" />
    <meta name="geo.position" content="-34.6037;-58.3816" />
    <meta name="ICBM" content="-34.6037, -58.3816" />

    <!-- Language -->
    <meta property="og:locale" content="es_AR" />
    <link rel="alternate" hreflang="es-AR" href={SITE_URL} />
    <link rel="alternate" hreflang="x-default" href={SITE_URL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Preconnect & Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={`${SITE_URL}/og-image.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Pato Ward Asesor de Seguros - Cotizá tu seguro online" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE_URL}/og-image.jpg`} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(insuranceAgencySchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body class="overflow-x-hidden">
    <slot />
    <style is:global>
      @import "../styles/global.css";
    </style>
  </body>
</html>
